# Gemini API Key (dapatkan gratis dari Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram API credentials (dapatkan dari my.telegram.org jika ingin menggunakan backend scraper)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
# Opsional: Telethon Session String jika berjalan di serverless Vercel
TELEGRAM_SESSION_STRING=your_session_string_here

# Database URL (Default menggunakan SQLite lokal jika tidak diset)
# Contoh Supabase: postgresql://postgres:password@db.supabase.co:5432/postgres
DATABASE_URL=sqlite:///./icd.db
